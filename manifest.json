{
  "manifest_version": 3,
  "name": "Aurio TTS",
  "version": "0.1.0",
  "description": "Leitor de páginas e PDFs com voz natural usando Azure AI Speech.",
  "action": { "default_popup": "src/popup/index.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*.tts.speech.microsoft.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "chunks/*",
        "**/*.mjs",
        "**/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "commands": {
    "pause": {
      "suggested_key": { "default": "Alt+Shift+P" },
      "description": "Pausar leitura"
    },
    "resume": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Retomar leitura"
    },
    "stop": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Parar leitura"
    }
  }
}


